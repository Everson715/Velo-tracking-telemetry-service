PORT=3003
NODE_ENV=development
LOG_LEVEL=info

DATABASE_URL=postgresql://tracking:tracking_secret@localhost:5433/tracking_db

REDIS_URL=redis://localhost:6380

JWT_SECRET=dev-jwt-secret-change-in-production
JWT_ISSUER=velo-identity
JWT_AUDIENCE=velo-platform

# Max GPS jump in meters before rejecting coordinate (anti-spoofing)
MAX_GPS_JUMP_METERS=500
